{
  "manifest_version": 3,
  "name": "LinuxIA Dock Terminal (V2)",
  "version": "2.0.0",
  "description": "Dock ChatGPT (haut) + ttyd terminal (bas) en 2 fenêtres collées, ON/OFF + barre.",
  "permissions": ["windows", "tabs", "storage", "scripting"],
  "host_permissions": [
    "https://chatgpt.com/*",
    "https://chat.openai.com/*",
    "http://127.0.0.1/*",
    "http://localhost/*"
  ],
  "background": { "service_worker": "background.js" },
  "action": { "default_title": "LinuxIA Dock Terminal" },
  "options_page": "options.html",
  "commands": {
    "toggle-dock": {
      "suggested_key": { "default": "Ctrl+Shift+Y" },
      "description": "Toggle Dock Terminal"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://chatgpt.com/*", "https://chat.openai.com/*"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ]
}

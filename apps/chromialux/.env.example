PORT=8787

# --- Dispatch end-of-route (default)
DISPATCH_MODE=ssh
SSH_HOST=192.168.1.50
SSH_PORT=22
SSH_USER=maitre
SSH_REMOTE_PATH=/home/maitre/ChromIAlux/inbox
# optionnel: forcer une clé particulière
SSH_KEY_PATH=/home/maitre/.ssh/id_ed25519

# --- Remote Relay SSH (aller-retour)
REMOTE_RELAY_ENABLED=0
REMOTE_RELAY_PROFILE=ami1
REMOTE_POLL_SECONDS=10

# Profil ami1
REMOTE_AMI1_HOST=example.com
REMOTE_AMI1_PORT=22
REMOTE_AMI1_USER=friend
REMOTE_AMI1_KEY_PATH=/home/maitre/.ssh/id_ed25519
REMOTE_AMI1_INBOX=/home/friend/chromialux/inbox
REMOTE_AMI1_OUTBOX=/home/friend/chromialux/outbox

# Profil ami2 (exemple)
# REMOTE_AMI2_HOST=other.example.com
# REMOTE_AMI2_PORT=22
# REMOTE_AMI2_USER=friend2
# REMOTE_AMI2_KEY_PATH=/home/maitre/.ssh/id_ed25519
# REMOTE_AMI2_INBOX=/home/friend2/chromialux/inbox
# REMOTE_AMI2_OUTBOX=/home/friend2/chromialux/outbox
